# Copy to .env and adjust. All variables optional — defaults target local dev.
# Settings precedence: process env > .env > coded defaults (see D16).

CHURNLENS_ENVIRONMENT=dev
CHURNLENS_LOG_LEVEL=INFO

# Override the data root (defaults to <repo>/data). Used by containers in Phase 17.
# CHURNLENS_DATA_DIR=/absolute/path/to/data
